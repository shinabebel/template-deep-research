# Model Configuration
# Specify your preferred AI model using the format: provider/model-name
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-5-20250929
#   google/gemini-2.5-pro
#   groq/llama-3.3-70b-versatile
#   ollama/gemma4:e4b-16k   (local — also set MODEL_BASE_URL below)
MODEL=openai/gpt-4o-mini

# Local / OpenAI-compatible endpoint. For local Ollama, point at the base URL
# ending in /v1 (NOT /api/chat). Leave empty when using a hosted provider.
#   MODEL_BASE_URL=http://localhost:11434/v1
MODEL_BASE_URL=

# Web search backend for webSearchTool. "exa" (default) or "ollama".
#   exa    -> uses EXA_API_KEY
#   ollama -> uses OLLAMA_API_KEY (Ollama's hosted web search API)
WEB_SEARCH_PROVIDER=exa

# API Keys (only needed for your chosen provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
EXA_API_KEY=""
# Ollama web search (hosted) API key — get one at https://ollama.com/settings/keys
OLLAMA_API_KEY=
